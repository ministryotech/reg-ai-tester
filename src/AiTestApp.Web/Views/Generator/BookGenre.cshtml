@{
    ViewData["Title"] = "Select Book Genre";
}

<div class="text-center">
    <h1 class="display-4 mb-5">Select a Genre</h1>

    <div class="row justify-content-center">
        <div class="col-md-3 mb-4">
            <a asp-action="Book" asp-route-genre="Science Fiction" class="btn btn-outline-primary btn-lg w-100 py-4">Science Fiction</a>
        </div>
        <div class="col-md-3 mb-4">
            <a asp-action="Book" asp-route-genre="Fantasy" class="btn btn-outline-primary btn-lg w-100 py-4">Fantasy</a>
        </div>
        <div class="col-md-3 mb-4">
            <a asp-action="Book" asp-route-genre="Horror" class="btn btn-outline-primary btn-lg w-100 py-4">Horror</a>
        </div>
        <div class="col-md-3 mb-4">
            <a asp-action="Book" asp-route-genre="Crime" class="btn btn-outline-primary btn-lg w-100 py-4">Crime</a>
        </div>
    </div>

    <div class="mt-5">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Back to Home</a>
    </div>
</div>
