@model AiTestApp.Models.TvShowViewModel
@{
    ViewData["Title"] = "Random TV Show";
}

<div class="text-center">
    <h1 class="display-4">@Model.Title (@Model.Year)</h1>
    <p class="lead"><strong>Genre:</strong> @Model.Genre</p>

    @if (!string.IsNullOrEmpty(Model.PosterUrl))
    {
        <div class="my-4">
            <img src="@Model.PosterUrl" alt="@Model.Title Poster" class="img-fluid rounded shadow-lg" style="max-height: 500px;" />
        </div>
    }

    <div class="card bg-light mx-auto my-4" style="max-width: 600px;">
        <div class="card-body">
            <p class="card-text">@Model.Description</p>
        </div>
    </div>

    <div class="mt-5">
        <a asp-controller="TvShows" asp-action="Index" class="btn btn-primary btn-lg px-4">Pick Another Random TV Show</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 ms-2">Back to Home</a>
    </div>
</div>
